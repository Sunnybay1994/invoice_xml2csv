		type: "POST",
		async: true,
		data:"orderId="+$("#orderId").val(),
		dataType: "json",
		success:function(data){
			if(data.result=='success'){
				console.log(data.postCompany+"\n"+data.postCompanyDiv+"\n"+data.deliveryDetailDiv);
				var postCompany=data.postCompany;
				if (postCompany!=null&&postCompany!=''){
					//收票信息 展示邮寄信息  运单号
					$("#invoiceAddressDivForAsync").append(data.postCompanyDiv);
					//进度条 展示 已邮寄
