function reloadQrCode(){
	var url = $("#qrCode").val();
	// console.log("QrCode:"+url);
	if(url != null && url != ''){
		$.ajax({
			url: url,
			dataType:'jsonp',
			data:'',
			jsonp:'callback',
			success:function(result) {
				if(result.success){
					$("#scanQrCode").show();
					$("#scanQrCode").attr("src", "data:image/png;base64,"+result.message);
				}else{
					$("#scanQrCode").hide();
					console.log("reloadQrCode:"+result);
				}
			},
			timeout:3000
		});
	}
}

