function bkfpReqForIvcLand(orderId,ivcType,ivcTitle,passKey,tagStr){
    var datas = "";
    datas += "orderId="+ orderId + "&";
    datas += "ivcType="+ ivcType + "&";
    datas += "ivcTitle="+ encodeURIComponent(encodeURIComponent(ivcTitle)) + "&";
    datas += "passKey="+ passKey + "&";
    datas += "ivcLandSource=1&";

    jQuery.ajax({
        type: "POST",
        async: false,
        url: "/fpzz/bkfpCheck.action",
        data:datas,
        dataType: "json",
        success: function(data){
            if (data.result == "invalid") {
                var baseHtml = $("#warning").html();
                $('body').dialog({
                    title:null,
                    width:520,
                    type:'text',
                    source: baseHtml.replace('$message$',data.message),
                    hasButton : true,
                    cancelButton:'确定',
                    submitButton : null
                });
            }else if(data.result == "success"){
                console.log(data)
                window.open("/fpzz/bkfpReqForIvcCenter.action?tagStr="+ tagStr + "&reqInfo="+data.reqInfo);
            }else{
                var baseHtml = $("#warning").html();
                $('body').dialog({
                    title:null,
                    width:520,
                    type:'text',
                    source: baseHtml.replace('$message$',"服务器忙，请稍后重试！"),
                    hasButton : true,
                    cancelButton:'确定',
                    submitButton : null
                });
            }
        },
        error : function(data){
            /*       		alert("服务器忙，请稍后重试！");  */
        }
    });
}


