function replaceBracketsByJquertObject(jquertObject) {
    CtoH(jquertObject);
    var inputValue = jquertObject.val();
    while (inputValue.indexOf("<") != -1) {
        inputValue = inputValue.replace("<", "[");
    }
    while (inputValue.indexOf(">") != -1) {
        inputValue = inputValue.replace(">", "]");
    }
    while (inputValue.indexOf("&") != -1) {
        inputValue = inputValue.replace("&", " ");
    }
    while (inputValue.indexOf("——") != -1) {
        inputValue = inputValue.replace("——", "-");
    }
    jquertObject.val($.trim(inputValue));
}

