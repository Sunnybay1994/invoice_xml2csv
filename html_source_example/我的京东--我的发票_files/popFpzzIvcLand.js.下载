//收票人地区
function validateArea(province, city, county, error) {
    var provinceNode = $("#"+province);
    var cityNode = $("#"+city);
    var countyNode = $("#"+county);
    if(!provinceNode.is(":hidden") && (provinceNode.val()=="" || provinceNode.val() == null || provinceNode.val() == undefined || provinceNode.val() == "null")){
        $("#" + error + "-error").show();
        $("#" + error + "-msg").html("请填写完整收票人地区");
        result = "请填写完整收票人地区";
        return result;
    }else if (!cityNode.is(":hidden") && (cityNode.val()=="" || cityNode.val() == null || cityNode.val() == undefined || cityNode.val() == "null")) {
        $("#" + error + "-error").show();
        $("#" + error + "-msg").html("请填写完整收票人地区");
        result = "请填写完整收票人地区";
        return result;
    }else if (!countyNode.is(":hidden") && (countyNode.val()=="" || countyNode.val() == null || countyNode.val() == undefined || countyNode.val() == "null")){
        $("#" + error + "-error").show();
        $("#" + error + "-msg").html("请填写完整收票人地区");
        result = "请填写完整收票人地区";
        return result;
    }else {
        $("#" + error + "-error").hide();
        $("#" + error + "-msg").html("");
    }
    return "";
}

//客户税号
function validateCusTaxNo(id) {
    var taxNo = $("#"+id);
    replaceBracketsByJquertObject(taxNo);
    taxNo.val(taxNo.val().toLocaleUpperCase());
    var reg_number=/(^([0-9A-Z]{15})|([0-9]{6}[0-9A-Z]{10,12})|([A-Z][0-9]{6}[0-9A-Z]{9,11})|([A-Z]{2}[0-9]{6}[0-9A-Z]{8,10})|([0-9]{14}[0-9X][0-9A-Z]{4,5})|([0-9]{17}[0-9X][0-9A-Z]{1,2})|([A-Z][0-9]{14}[0-9X][0-9A-Z]{3,4})|([A-Z][0-9]{17}[0-9X][0-9A-Z]{0,1})|([0-9]{6}[0-9A-Z]{14})$)/;
    if(taxNo.val()==null || taxNo.val()==''){
        changeValidateStatusForIvcLand(false, id, "请填写发票税号");
        result = "请填写发票税号";
        return result;
    }else if(!reg_number.test(taxNo.val())) {
        changeValidateStatusForIvcLand(false, id, "税号为10到20位数字字母组合，请检查");
        result = "税号为10到20位数字字母组合，请检查";
        return result;
    }else if(checkUrl(taxNo.val())){
        changeValidateStatusForIvcLand(false, id, "税号包含特殊字符，请检查");
        result = "税号包含特殊字符，请检查";
        return result;
    }else {
        changeValidateStatusForIvcLand(true, id, "");
    }
    return "";
}
//客户税号
function validateCusTaxNoAndCanNull(id,isCanNull) {
    var taxNo = $("#"+id);
    replaceBracketsByJquertObject(taxNo);
    taxNo.val(taxNo.val().toLocaleUpperCase());
    var reg_number=/(^([0-9A-Z]{15})|([0-9]{6}[0-9A-Z]{10,12})|([A-Z][0-9]{6}[0-9A-Z]{9,11})|([A-Z]{2}[0-9]{6}[0-9A-Z]{8,10})|([0-9]{14}[0-9X][0-9A-Z]{4,5})|([0-9]{17}[0-9X][0-9A-Z]{1,2})|([A-Z][0-9]{14}[0-9X][0-9A-Z]{3,4})|([A-Z][0-9]{17}[0-9X][0-9A-Z]{0,1})|([0-9]{6}[0-9A-Z]{14})$)/;
    if(!isCanNull&&(taxNo.val()==null || taxNo.val()=='')){
        changeValidateStatusForIvcLand(false, id, "请填写发票税号");
        result = "请填写发票税号";
        return result;
    }if(isCanNull&&(taxNo.val()==null || taxNo.val()=='')){//如果允许为空，并且税号为空 则直接返回
        return "";
    }else if(!reg_number.test(taxNo.val())) {
        changeValidateStatusForIvcLand(false, id, "税号为10到20位数字字母组合，请检查");
        result = "税号为10到20位数字字母组合，请检查";
        return result;
    }else if(checkUrl(taxNo.val())){
        changeValidateStatusForIvcLand(false, id, "税号包含特殊字符，请检查");
        result = "税号包含特殊字符，请检查";
        return result;
    }else {
        changeValidateStatusForIvcLand(true, id, "");
    }
    return "";
}

//注册地址
function validateRegistAddress(id) {
    var address = $("#"+id);
    if(address.val()=='' || address.val()==null){
        changeValidateStatusForIvcLand(true, id, "");
        return "";
    }
    address.val(address.val().replace(/\s+/g, ""));
    replaceBracketsByJquertObject(address);
    if (address.val().replace(/[^\x00-\xff]/g, "**").length < 2) {
        changeValidateStatusForIvcLand(false, id, "注册地址错误");
        return "注册地址错误";
    }else if (checkLength(address.val()) >80) {
        changeValidateStatusForIvcLand(false, id, "注册地址过长，请重新输入");
        result = "注册地址过长，请重新输入";
        return result;
    }else if(!(/.*[\u4e00-\u9fa5]+.*$/.test(address.val()))){
        changeValidateStatusForIvcLand(false, id, "注册地址必须包含汉字，请重新输入");
        result = "注册地址必须包含汉字，请重新输入";
        return result;
    }else if (stripscript(address.val())) {
        changeValidateStatusForIvcLand(false, id, "注册地址含有特殊字符，请重新输入");
        result = "注册地址含有特殊字符，请重新输入";
        return result;
    }else if (hasEmoji(address.val())) {
        changeValidateStatusForIvcLand(false, id, "注册地址含有表情符号，请重新输入");
        result = "注册地址含有表情符号，请重新输入";
        return result;
    } else {
        changeValidateStatusForIvcLand(true, id, "");
    }
    return "";
}

