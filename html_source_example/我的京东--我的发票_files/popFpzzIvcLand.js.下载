    return "";
}

//验证电子票邮箱
function validateEmail(id) {
    var email = $("#"+id);
    replaceBracketsByJquertObject(email);
    var re = /^[A-Za-z\d]+([-_.][A-Za-z\d]+)*@([A-Za-z\d]+[-.])+[A-Za-z\d]{2,4}$/ ; // 判断是否为邮箱的正则表达式
    if(email.val()==null || email.val()==""){
        changeValidateStatusForIvcLand(true, id, "");
        return "";
    }else if (!(re.test(email.val()))){
        changeValidateStatusForIvcLand(false, id, "邮箱格式不正确，请重新输入");
        result = "邮箱格式不正确，请重新输入";
        return result;
    }else if (checkLength(email.val())>100) {
        changeValidateStatusForIvcLand(false, id, "邮箱过长，请重新输入");
        result = "邮箱过长，请重新输入";
        return result;
    }else if (stripscriptForEmail(email.val())) {
        changeValidateStatusForIvcLand(false, id, "邮箱含有特殊字符，请重新输入");
        result = "邮箱含有特殊字符，请重新输入";
        return result;
    }else {
        changeValidateStatusForIvcLand(true, id, "");
    }
    return "";
}

