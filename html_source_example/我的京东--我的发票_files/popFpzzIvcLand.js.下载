function doPopBkfpReq(obj,orderId,venderId,passKey){
    var message="";
    var datas = "";

    datas += "ivcContent=1&";//默认开明细发票
    var ivcType = $("#ivcType").val();
    datas += "ivcType="+ivcType+"&";
    var ivcTitleType;
    if (ivcType == 2) {
        ivcTitleType = $("#ivcTitleTypeCompany").find("option:selected").text();
    }else {
        ivcTitleType = $("#ivcTitleTypeAll").find("option:selected").text();
    }

    if(ivcTitleType == ""){
        message="请选择发票抬头！"
    }
    if(ivcTitleType != '个人'){
        datas += "ivcTitleType="+ 5 + "&";

        var companyNameResult = validateCompanyName('companyName','单位名称');
        if(companyNameResult !=""){
            message = companyNameResult;
        }else{
            datas += "ivcTitle="+ encodeURIComponent(encodeURIComponent($("#companyName").val())) + "&";
        }

        var taxNoResult = validateCusTaxNoAndCanNull('taxNo',true);
        if(taxNoResult !=""){
            message = taxNoResult;
        }else{
            datas += "taxNo="+ $("#taxNo").val() + "&";
        }

        var eiRegistAddressResult = validateRegistAddress("eiRegistAddress");
        if (eiRegistAddressResult != "") {
            message = eiRegistAddressResult;
        }else{
            datas += "registAddress="+ encodeURIComponent(encodeURIComponent($("#eiRegistAddress").val())) + "&";
        }

        var eiRegistPhoneResult = validatePhone("eiRegistPhone");
        if (eiRegistPhoneResult != "") {
            message = eiRegistPhoneResult;
        }else{
            datas += "registPhone="+ $("#eiRegistPhone").val() + "&";
        }

        var eiBankResult = validateBank("eiBank");
        if (eiBankResult != "") {
            message = eiBankResult;
        }else{
            datas += "bank="+ encodeURIComponent(encodeURIComponent($("#eiBank").val())) + "&";
        }

        var eiBankAccountResult = validateAccount("eiBankAccount");
        if (eiBankAccountResult != "") {
            message = eiBankAccountResult;
        }else{
            datas += "bankAccount="+ $("#eiBankAccount").val() + "&";
        }

        var showUserStatement = $("#showUserStatement").val();
        var statementChecked = $("#chechbox-statement").attr("checked");
        if (showUserStatement == "true" && statementChecked != "checked") {
            message = "请阅读并勾选声明";
        }
    }else{
        datas += "ivcTitleType="+ 4 + "&";

        var ivcTitleResult = validatePersonName('ivcTitle','发票抬头');
        if(ivcTitleResult !=""){
            message = ivcTitleResult;
        }else{
            if($("#ivcTitle").val()==null || $("#ivcTitle").val() ==""){
                datas += "ivcTitle="+ encodeURIComponent(encodeURIComponent('个人')) + "&";
            }else{
                datas += "ivcTitle="+ encodeURIComponent(encodeURIComponent($("#ivcTitle").val())) + "&";
            }
        }
    }

    if (ivcType == 1 || ivcType == 2) {
        var areaResult = validateAddAddress();
        if(areaResult != ""){
            message = areaResult;
        }

        var customerName = $("#customerName").val();
        datas += "customerName="+ encodeURIComponent(encodeURIComponent(customerName)) + "&";

        var customerTel = $("#customerTel").val();
        datas += "customerTel="+ customerTel + "&";

        var provinceNum = $("#provinceNum").val();
        datas += "province="+ provinceNum + "&";
        datas += "provinceName="+ $("#provinceNum").find("option:selected").text() + "&";

        var provinceName = $("#provinceNum").find("option:selected").text();
        if( provinceName=="香港" || provinceName=="澳门" || provinceName=="台湾" || provinceName=="海外" ){
            datas += "city="+ 0 + "&";
            datas += "county="+ 0 + "&";
        }else{
            datas += "city="+ $("#cityNum").val() + "&";
            datas += "cityName="+ $("#cityNum").find("option:selected").text() + "&";
            datas += "county="+ $("#countyNum").val() + "&";
            datas += "countyName="+$("#countyNum").find("option:selected").text() + "&";
        }

        var address = provinceName+$("#cityNum").find("option:selected").text()+$("#countyNum").find("option:selected").text()+$("#address").val();
        datas += "address="+ encodeURIComponent(encodeURIComponent(address)) + "&";
    }else {
        var customerTelResult = validateTelephone("customerTelE");
        if (customerTelResult != "") {
            message = customerTelResult;
        }else{
            datas += "customerTel="+ $("#customerTelE").val() + "&";
        }

        var customerEmailResult = validateEmail("email");
        if (customerEmailResult != "") {
            message = customerEmailResult;
        }else{
            datas += "email="+ $("#email").val() + "&";
        }
    }

    if(message !=""){
        var baseHtml = $("#warning").html();
        $('body').dialog({
            title:null,
            width:520,
            type:'text',
            source: baseHtml.replace('$message$',message),
            hasButton : true,
            cancelButton:'确定',
            submitButton : null
        });
        return;
    }

    datas += "orderId="+ orderId + "&";
    datas += "venderId="+ venderId + "&";
    datas += "passKey="+ passKey + "&";
    datas += "tagStr="+ $("#tagStr").val() + "&";

    $(obj).css("display","none");
    $.ajax({
        type: "POST",
        url: "/popFpzz/doPopBkfpReq.action",
        data: datas,
        dataType: "json",
        success: function(data){
            $(obj).removeAttr("style");
            if (data.result == "invalid") {
                var baseHtml = $("#warning").html();
                $('body').dialog({
                    title:null,
                    width:520,
                    type:'text',
                    source: baseHtml.replace('$message$',data.message),
                    hasButton : true,
                    cancelButton:'确定',
                    submitButton : null
                });
            }else if(data.result == "success"){
                var baseHtml = $("#success").html();
                $('body').dialog({
                    title:null,
                    width:520,
                    type:'text',
                    source: baseHtml.replace('$message$',data.message),
                    hasButton : true,
                    cancelButton:'确定',
                    submitButton : null,
                    onCancel:function(){
                        // window.opener=null;window.close();
                        window.location.replace(data.ivcLandUrl);
                    }
                });
            }else{
                var baseHtml = $("#warning").html();
                $('body').dialog({
                    title:null,
                    width:520,
                    type:'text',
                    source: baseHtml.replace('$message$',"服务器忙，请稍后重试！"),
                    hasButton : true,
                    cancelButton:'确定',
                    submitButton : null
                });
            }
        },
        error : function(data){
            $(obj).removeAttr("style");
        }
    });
}

function validateAddAddress() {
    var customerNameResult = validateUsername("customerName");
    if (customerNameResult !="") {
        return customerNameResult;
    }
    var customerTelResult = validateTelephone("customerTel");
    if (customerTelResult != "") {
        return customerTelResult;
    }
    var addressResult = validateCusAddress("address");
    if (addressResult != "") {
        return addressResult;
    }
    var areaResult = validateArea("provinceNum", "cityNum", "countyNum", "area");
    if (areaResult != "") {
        return areaResult;
    }
    return "";
}

//增票人姓名
function validateUsername(id) {
    var username = $("#"+id);
    replaceBracketsByJquertObject(username);
    if(username.val()==null || username.val()==""){
        changeValidateStatusForIvcLand(false, id, "请填写收票人姓名");
        result = "请填写收票人姓名";
        return result;
    }else if (checkLength(username.val())>20) {
        changeValidateStatusForIvcLand(false, id, "收票人姓名过长，请重新输入");
        result = "收票人姓名过长，请重新输入";
        return result;
    }else if (stripscript(username.val())){
        changeValidateStatusForIvcLand(false, id, "收票人含有特殊字符，请重新输入");
        result = "收票人含有特殊字符，请重新输入";
        return result;
    }else if (hasEmoji(username.val())){
        changeValidateStatusForIvcLand(false, id, "收票人含有表情符号，请重新输入");
        result = "收票人含有表情符号，请重新输入";
        return result;
    }else {
        changeValidateStatusForIvcLand(true, id, "");
    }
    return "";
}

//收票人联系方式
function validateTelephone(id) {
    var telephone = $("#"+id);
    replaceBracketsByJquertObject(telephone);
    var re = /^1{1}[3,4,5,6,7,8,9]{1}\d{9}$/; // 判断是否为数字的正则表达式
    if(telephone.val()==null || telephone.val()==""){
        changeValidateStatusForIvcLand(false, id, "请填写收票人手机号");
        result = "请填写收票人手机号";
        return result;
    }else if (!(re.test(telephone.val()) || /^\d{3}\*\*\*\*\d{4}$/.test(telephone.val()))){
        changeValidateStatusForIvcLand(false, id, "收票人手机号格式不正确，请重新输入");
        result = "收票人手机号格式不正确，请重新输入";
        return result;
    }else if (checkLength(telephone.val())>20) {
        changeValidateStatusForIvcLand(false, id, "收票人手机号过长，请重新输入");
        result = "收票人手机号过长，请重新输入";
        return result;
    }else if (stripscriptForTel(telephone.val())){
        changeValidateStatusForIvcLand(false, id, "收票人手机号含有特殊字符，请重新输入");
        result = "收票人手机号含有特殊字符，请重新输入";
        return result;
    } else {
        changeValidateStatusForIvcLand(true, id, "");
    }
    return "";
}

